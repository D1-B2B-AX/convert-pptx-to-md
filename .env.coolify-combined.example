# Coolify Docker Compose stack example.
# Do not commit real production secrets.

N8N_VERSION=latest
N8N_HOST=ax-workflow.skillflo.app
N8N_PROTOCOL=https
WEBHOOK_URL=https://ax-workflow.skillflo.app/
N8N_EDITOR_BASE_URL=https://ax-workflow.skillflo.app/

GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# Keep this equal to the existing n8n volume if you are migrating an existing n8n.
N8N_DATA_VOLUME=n8n-data

# Must match the existing n8n encryption key if you want old credentials to keep working.
N8N_ENCRYPTION_KEY=replace-with-existing-n8n-encryption-key

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional but recommended. n8n must send Authorization: Bearer <this value>.
API_AUTH_TOKEN=replace-with-long-random-token
